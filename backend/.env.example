# ---------------------------------------------------------------------------
# Backend environment variables (copy to .env and fill in)
# ---------------------------------------------------------------------------

# Supabase project URL (Project Settings -> API -> Project URL)
SUPABASE_URL=

# Supabase service_role key (Project Settings -> API -> service_role).
# SECRET. Bypasses RLS. Never expose to the frontend / commit this value.
SUPABASE_SERVICE_ROLE_KEY=

# URL of the frontend (used for CORS). Local dev default below.
FRONTEND_URL=http://localhost:3000

# Port the API listens on.
PORT=4000

# ---------------------------------------------------------------------------
# Integration tests (`npm test`). The live business-rule suite runs only when
# all three of SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY and the anon key below
# are set; it mints fresh demo-user tokens at runtime (no static tokens needed).
# Otherwise that suite is skipped and only unit/smoke tests run.
# ---------------------------------------------------------------------------
# Supabase anon public key (Project Settings -> API -> anon public).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
