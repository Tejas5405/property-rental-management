# ---------------------------------------------------------------------------
# Backend environment variables (copy to .env and fill in)
# ---------------------------------------------------------------------------

# Supabase project URL (Project Settings -> API -> Project URL)
SUPABASE_URL=

# Supabase service_role key (Project Settings -> API -> service_role).
# SECRET. Bypasses RLS. Never expose to the frontend / commit this value.
SUPABASE_SERVICE_ROLE_KEY=

# URL of the frontend (used for CORS). Local dev default below.
FRONTEND_URL=http://localhost:3000

# Port the API listens on.
PORT=4000

# ---------------------------------------------------------------------------
# Integration test tokens (used by `npm test`). Obtain after seeding by
# signing in as each demo user (see README "How to get test tokens").
# ---------------------------------------------------------------------------
TEST_ADMIN_TOKEN=
TEST_MANAGER_TOKEN=
TEST_TENANT_TOKEN=
TEST_TENANT_ID=
